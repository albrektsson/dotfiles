{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".github/copilot-instructions.md",
    ".github/instructions/*.instructions.md"
  ],
  "lsp": true,
  "share": "disabled",
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  },
  "permission": {
      "bash": {
          "*": "ask",

          "find *": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "egrep *": "allow",
          "fgrep *": "allow",
          "ag *": "allow",

          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "sort *": "allow",
          "uniq *": "allow",
          "cut *": "allow",
          "tr *": "allow",
          "awk *": "allow",
          "sed *": "allow",
          "echo *": "allow",
          "printf *": "allow",
          "jq *": "allow",
          "yq *": "allow",

          "ls *": "allow",
          "ls": "allow",
          "stat *": "allow",
          "file *": "allow",
          "which *": "allow",
          "type *": "allow",
          "pwd": "allow",
          "date": "allow",
          "diff": "allow",

          "git status *": "allow",
          "git status": "allow",
          "git log *": "allow",
          "git diff *": "allow",
          "git diff": "allow",
          "git show *": "allow",
          "git branch *": "allow",
          "git branch": "allow",
          "git remote *": "allow",

          "kubectl get *": "allow",
          "kubectl describe *": "allow",
          "kubectl logs *": "allow",

          "./gradlew *": "allow",
          "go build *": "allow",
          "go vet *": "allow",
          "go test *": "allow",
          "go version": "allow",
          "go doc *": "allow",

          "rm *": "ask",
          "rmdir *": "ask",
          "sudo *": "deny",
          "su *": "deny",
          "chmod *": "deny",
          "chown *": "deny",
          "kill *": "deny",
          "pkill *": "deny",
          "dd *": "deny",
          "ssh *": "deny",
          "scp *": "deny"
      },
      "codesearch": "allow",
      "webfetch": "allow",
      "grep": "allow",
      "glob": "allow",
      "list": "allow",
      "skill": "ask",
      "lsp": "allow",
      "todowrite": "allow",
      "question": "allow",
      "read": {
          "*": "allow",
          "*.env": "ask"
      },
      "edit": "allow",
      "external_directory": {
          "*": "deny",
          "/tmp/**": "allow",
          "{env:HOME}/**": "ask"
      },
      "doom_loop": "ask"
  }
}
