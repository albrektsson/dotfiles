[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
[user]
    signingkey = EA22039549037368
    name = Emil Albrektsson
    email = 61695840+albrektsson@users.noreply.github.com
[commit]
    gpgsign = true
[pull]
    rebase = false
[init]
    defaultBranch = main
[core]
    editor = vim --nofork
    hooksPath = ~/.config/git/hooks
[include]
    path = ~/.gitconfig.local
